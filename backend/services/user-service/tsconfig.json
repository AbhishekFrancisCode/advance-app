{
"compilerOptions": {
"module": "commonjs",
"moduleResolution": "node",
"target": "ES2023",

"rootDir": "./src",
"outDir": "./dist",

"baseUrl": "./",
"paths": {
  "src/*": ["src/*"]
},

"emitDecoratorMetadata": true,
"experimentalDecorators": true,

"esModuleInterop": true,
"skipLibCheck": true,
"strictNullChecks": true

},
"include": ["src/**/*.ts"],
"exclude": ["node_modules", "dist"]
}
